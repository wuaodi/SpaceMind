  "tasks": {
    "rendezvous-hold-front": {
      "task_family": "relative-hold",
      "evaluation_profile": "final_distance_band_success",
      "capability_tags": [
        "relative_navigation",
        "hold_stability"
      ],
      "default_tool_profile": "hybrid_nav",
      "benchmark_goal": "final surface distance 1-3m without collision",
      "supported_tool_profiles": [
        "oracle_full",
        "hybrid_nav",
        "hybrid_nav_with_code",
        "vision_only"
      ],
      "user_task": "Mission: The target is already in view. Approach the target spacecraft and stop once the final distance to the target surface is about 2 meters.",
      "fallback_dynamic_skills": [
        "task-rendezvous",
        "distance-strategy"
      ]
    },
    "search-then-approach": {
      "task_family": "search-and-approach",
      "evaluation_profile": "final_distance_band_success",
      "capability_tags": [
        "relative_navigation",
        "hold_stability",
        "initial_target_acquisition",
        "recovery",
        "safe_abort"
      ],
      "default_tool_profile": "hybrid_nav",
      "benchmark_goal": "target initially out of view, then final surface distance 1-3m without collision",
      "supported_tool_profiles": [
        "oracle_full",
        "hybrid_nav",
        "hybrid_nav_with_code",
        "vision_only"
      ],
      "user_task": "Mission: The target is not initially in view. Search for the target, regain a reliable observation, then approach the target spacecraft and stop once the final distance to the target surface is about 2 meters. If the target cannot be recovered safely, terminate with a clear target-lost reason.",
      "fallback_dynamic_skills": [
        "task-search-approach",
        "target-recovery",
        "distance-strategy"
      ]
    },
    "inspection-diagnosis": {
      "task_family": "inspection-diagnosis",
      "evaluation_profile": "inspection_diagnosis_model_score",
      "capability_tags": [
        "local_inspection",
        "semantic_diagnosis"
      ],
      "default_tool_profile": "hybrid_nav",
      "benchmark_goal": "model-scored diagnosis against hidden inspection labels",
      "supported_tool_profiles": [
        "oracle_full",
        "hybrid_nav",
        "hybrid_nav_with_code",
        "vision_only"
      ],
      "user_task": "Mission: Inspect the target spacecraft and report: (1) spacecraft type, (2) key visible components with counts, (3) visual appearance (shape, color, size), (4) likely function or mission, (5) operational status. Call terminate_navigation with a diagnosis covering all five aspects.",
      "fallback_dynamic_skills": [
        "task-inspection",
        "perception-strategy"
      ]
    }
  },
