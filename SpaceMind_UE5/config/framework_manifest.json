{
  "capability_dimensions": [
    "relative_navigation",
    "hold_stability",
    "initial_target_acquisition",
    "local_inspection",
    "semantic_diagnosis",
    "recovery",
    "safe_abort"
  ],
  "task_families": {
    "relative-hold": {
      "description": "Approach a visible target and stop at a safe near-distance band.",
      "coverage": [
        "relative_navigation",
        "hold_stability"
      ],
      "primary_metrics": [
        "success_rate",
        "collision_rate",
        "avg_steps",
        "avg_tool_calls",
        "final_surface_distance_m"
      ],
      "subtasks": [
        "rendezvous-hold-front"
      ]
    },
    "search-and-approach": {
      "description": "Search for a target that is initially outside the field of view, then approach to a safe near-distance band.",
      "coverage": [
        "relative_navigation",
        "hold_stability",
        "initial_target_acquisition",
        "recovery",
        "safe_abort"
      ],
      "primary_metrics": [
        "success_rate",
        "collision_rate",
        "avg_steps",
        "avg_tool_calls",
        "final_surface_distance_m"
      ],
      "subtasks": [
        "search-then-approach"
      ]
    },
    "inspection-diagnosis": {
      "description": "Inspect the visible target, reason about components and status, and score the final diagnosis against hidden truth labels.",
      "coverage": [
        "local_inspection",
        "semantic_diagnosis"
      ],
      "primary_metrics": [
        "inspection_score",
        "avg_tool_calls",
        "avg_sensing_calls"
      ],
      "subtasks": [
        "inspection-diagnosis"
      ]
    }
  },
