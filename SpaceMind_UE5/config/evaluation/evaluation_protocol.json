{
  "signal_sources": {
    "semantic_truth": {
      "description": "Per-target labels for type, visible components, and mission-relevant semantics.",
      "visibility_to_agent": false,
      "typical_use": [
        "inspection scoring"
      ]
    },
    "lidar_points": {
      "description": "Point-cloud or range observations from the simulated lidar sensor.",
      "visibility_to_agent": "optional",
      "typical_use": [
        "final distance-band validation"
      ]
    },
    "pose_truth": {
      "description": "Ground-truth servicer position relative to the target (target fixed at world origin), published by the simulation bridge.",
      "visibility_to_agent": false,
      "typical_use": [
        "final cone-position validation"
      ]
    },
    "collision_state": {
      "description": "Collision counter and contact events from the simulator.",
      "visibility_to_agent": false,
      "typical_use": [
        "hard failure detection"
      ]
    }
  },
  "global_rules": {
    "contact_is_failure_for_precontact_tasks": true,
    "success_requires_collision_free_episode": true,
    "success_requires_hidden_evaluator_match": true
  },
  "evaluation_profiles": {
    "final_distance_band_success": {
      "goal_type": "final_distance_band_success",
      "required_signals": [
        "lidar_points",
        "collision_state"
      ],
      "success_conditions": {
        "surface_distance_range_m": [
          1.0,
          3.0
        ],
        "collision_free": true
      },
      "failure_conditions": {
        "collision": true,
        "timeout": true,
        "missing_lidar": true,
        "delta_v_exceeded": true
      }
    },
    "final_cone_position_success": {
      "goal_type": "final_cone_position_success",
      "required_signals": [
        "pose_truth",
        "collision_state"
      ],
      "success_conditions": {
        "cone_half_angle_deg": 45.0,
        "center_distance_range_m": [
          3.0,
          7.0
        ],
        "collision_free": true
      },
      "failure_conditions": {
        "collision": true,
        "timeout": true,
        "missing_pose_truth": true,
        "out_of_cone": true,
        "distance_out_of_range": true,
        "delta_v_exceeded": true
      }
    },
    "inspection_diagnosis_model_score": {
      "goal_type": "semantic_model_score",
      "required_signals": [
        "semantic_truth"
      ],
      "truth_source": {
        "file": "benchmark_annotation_template.json",
        "section": "satellites.<target_name>.inspection_labels"
      },
      "score_range": [
        0,
        100
      ],
      "reported_metrics": [
        "inspection_score"
      ]
    }
  },
  "task_to_profile": {
    "rendezvous-hold-front": "final_distance_band_success",
    "search-then-approach": "final_distance_band_success",
    "inspection-diagnosis": "inspection_diagnosis_model_score",
    "fly-around-above": "final_cone_position_success"
  }
}
