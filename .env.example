# Copy this file to .env and fill in the real values before running.

# Model provider credentials
MODELSCOPE_API_KEY=
MODELSCOPE_BASE_URL=

METACHAT_API_KEY=
METACHAT_BASE_URL=

# Runtime defaults
SPACEMIND_MODEL=qwen3-vl-235b
SPACEMIND_THINKING_ENABLED=true

# Optional (for standalone demo scripts)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
